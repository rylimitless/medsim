# PostgreSQL Configuration
POSTGRES_USER=medsim
POSTGRES_PASSWORD=medsim_password
POSTGRES_DB=medsim
DATABASE_URL=postgresql://medsim:medsim_password@localhost:5432/medsim

# OpenRouter API Key (for embeddings and voice control)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# OpenRouter Model Configuration
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
OPENROUTER_TRANSCRIPTION_MODEL=google/gemini-3-flash-preview
OPENROUTER_CLASSIFICATION_MODEL=google/gemini-3-flash-preview
