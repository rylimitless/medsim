# PostgreSQL Configuration
POSTGRES_USER=medsim
POSTGRES_PASSWORD=medsim_password
POSTGRES_DB=medsim
DATABASE_URL=postgresql://medsim:medsim_password@localhost:5432/medsim

# OpenRouter API Key (for embeddings and voice control)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# Google GenAI API Key (for voice control - optional, for alternative models)
# Get your API key from: https://ai.google.dev/
GOOGLE_GENAI_API_KEY=your_google_genai_api_key

# Google GenAI Model Name (default: gemini-3-flash-preview)
# Available models: gemini-3-flash-preview, gemini-3-pro-preview, gemini-2.0-flash, gemini-2.5-flash
GOOGLE_GENAI_MODEL=gemini-3-flash-preview
